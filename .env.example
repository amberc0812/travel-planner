# --- Database (Neon Postgres) ---
# Added automatically when you attach the Neon integration to the Vercel project.
# For local dev, run `vercel env pull .env.local` after linking the project.
DATABASE_URL=

# --- Email (Resend — https://resend.com) ---
# Verify a sending DOMAIN in Resend for reliable inbox delivery. Unverified
# senders frequently land in spam, which looks the same as "he didn't receive it".
RESEND_API_KEY=
EMAIL_FROM="Travel Planner <noreply@yourdomain.com>"

# --- Optional ---
# Override the base URL used when building share links (defaults to the request host).
# PUBLIC_BASE_URL=https://your-app.vercel.app
